{
  "name": "life-game",
  "private": true,
  "version": "0.1.0",
  "description": "LIFE GAME monorepo for a web-based political and economic simulation.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "dev:game": "npm --workspace @life-game/game run dev",
    "dev:wiki": "npm --workspace @life-game/wiki run dev"
  },
  "dependencies": {
    "@docusaurus/theme-classic": "3.6.3",
    "caniuse-lite": "^1.0.30001700",
    "lodash": "4.17.21",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "webpack": "5.97.1"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
